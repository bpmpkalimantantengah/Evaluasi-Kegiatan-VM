<style>

/* CSS Spinner untuk Logout */
@keyframes spinner-border {
  to { transform: rotate(360deg); }
}
.spinner-border {
  display: inline-block;
  width: 1rem;
  height: 1rem;
  vertical-align: -0.125em;
  border: 0.15em solid currentColor;
  border-right-color: transparent;
  border-radius: 50%;
  animation: 0.75s linear infinite spinner-border;
}
.spinner-border-sm {
  width: 14px !important;
  height: 14px !important;
  border-width: 2px !important;
}



  /*Reset & Base*/
/* ── ROOT ────────────────────────────────────────────────── */
:root {
  --gp: #003366; --gp2: #0a4080; --gp3: rgba(0,51,102,0.08);
  --gs: #1E90FF; --gs2: #0070e0;
  --ga: #FFEB3B; --ga2: #f0d800;
  --white: #ffffff; --bg: #f0f4f8; --card: #ffffff;
  --text: #1a2332; --text2: #4a5568; --text3: #8a9bb0;
  --border: rgba(0,51,102,0.12);
  --success: #22c55e; --danger: #ef4444; --warn: #f59e0b;
  --radius: 10px; --radius-lg: 16px;
  --shadow: 0 2px 12px rgba(0,51,102,0.08);
  --sidebar-w: 260px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
a { text-decoration: none; color: inherit; }
input, button, select, textarea { font-family: inherit; }

/* ── UTILITIES ───────────────────────────────────────────── */
.hidden { display: none !important; }
.flex { display: flex; }
.items-center { align-items: center; }
.gap-8 { gap: 8px; }
.gap-12 { gap: 12px; }
.w-full { width: 100%; }
.text-sm { font-size: 13px; }
.text-xs { font-size: 11px; }

#toast-wrap { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999; display: flex; flex-direction: column; gap: 8px; align-items: center; pointer-events: none; }
.gaspol-toast { pointer-events: auto; padding: 12px 24px; border-radius: 50px; font-size: 14px; font-weight: 500; color: #fff; animation: toastIn .3s cubic-bezier(0.175, 0.885, 0.32, 1.275); min-width: 200px; display: flex; align-items: center; justify-content: center; gap: 10px; box-shadow: 0 8px 20px rgba(0,0,0,0.2); background: #002244; }
.toast-success { background: #166534; } .toast-error { background: #991b1b; } .toast-info { background: #002244; } .toast-warning { background: #b45309; }
@keyframes toastIn { from { opacity:0; transform:scale(0.8) translateY(20px); } to { opacity:1; transform:scale(1) translateY(0); } }

/* ── LOADING ─────────────────────────────────────────────── */
#loading { position:fixed; inset:0; background:var(--gp); display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:9000; gap:16px; }
#loading .logo-text { color:var(--ga); font-size:32px; font-weight:800; letter-spacing:3px; }
#loading .logo-sub  { color:rgba(255,255,255,0.6); font-size:11px; letter-spacing:1px; }
.spinner { width:36px; height:36px; border:3px solid rgba(255,235,59,.3); border-top-color:var(--ga); border-radius:50%; animation:spin .7s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }

/* ── SIDEBAR ─────────────────────────────────────────────── */
.sidebar { width:var(--sidebar-w); background:var(--gp); position:fixed; top:0; left:0; bottom:0; z-index:100; display:flex; flex-direction:column; transition:transform .3s; }
.sidebar-head { height:64px; padding:0 20px; border-bottom:1px solid rgba(255,255,255,.08); display:flex; align-items:center; gap:12px; background: #002244; box-sizing: border-box; }
.sidebar-icon { width:38px; height:38px; background:var(--ga); border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.sidebar-icon i { font-size:22px; color:var(--gp); }
.sidebar-brand-name { color:#fff; font-size:13px; font-weight:800; letter-spacing:1px; line-height:1.2; }
.sidebar-brand-sub  { color:rgba(255,255,255,.4); font-size:9px; letter-spacing:.8px; margin-top:2px; }
nav.sidebar-nav { flex:1; padding:12px 0; overflow-y:auto; }
.nav-section { font-size:9px; font-weight:700; color:rgba(255,255,255,.3); letter-spacing:1.2px; padding:12px 18px 4px; text-transform:uppercase; }
.nav-item { display:flex; align-items:center; gap:10px; padding:10px 18px; cursor:pointer; color:rgba(255,255,255,.6); font-size:13px; font-weight:400; border-left:3px solid transparent; transition:all .15s; user-select:none; }
.nav-item:hover { background:rgba(255,255,255,.06); color:rgba(255,255,255,.9); }
.nav-item.active { background:rgba(30,144,255,.18); color:#fff; border-left-color:var(--ga); font-weight:500; }
.nav-item i { font-size:18px; flex-shrink:0; }
.sidebar-bottom { padding:14px 18px; border-top:1px solid rgba(255,255,255,.08); }
.sidebar-user-info { display:flex; align-items:center; gap:10px; padding:8px 0; }
.user-avatar { width:34px; height:34px; border-radius:50%; background:var(--ga); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:800; color:var(--gp); flex-shrink:0; }
.user-name { color:#fff; font-size:12px; font-weight:500; }
.user-sub  { color:rgba(255,255,255,.4); font-size:10px; }
.btn-logout { width:100%; margin-top:8px; padding:8px; border-radius:var(--radius); border:1px solid rgba(255,255,255,.15); background:transparent; color:rgba(255,255,255,.6); font-size:12px; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:6px; transition:all .15s; }
.btn-logout:hover { background:rgba(239,68,68,.2); border-color:rgba(239,68,68,.4); color:#fca5a5; }

/* ── MAIN CONTENT ────────────────────────────────────────── */
.main-content { margin-left:var(--sidebar-w); min-height:100vh; display:flex; flex-direction:column; }
.topbar { height:64px; padding:0 28px; background:#002244; box-shadow:0 2px 8px rgba(0,0,0,0.3); display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:50; box-sizing: border-box; }
.topbar-title { font-size:15px; font-weight:700; color:#fff; }
.topbar-sub   { font-size:12px; color:rgba(255,255,255,0.7); margin-top:1px; }
.topbar-actions { display:flex; gap:12px; align-items:center; }
.icon-btn { width:36px; height:36px; border-radius:var(--radius); border:1.5px solid rgba(255,255,255,0.2); background:transparent; color:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all .15s; }
.icon-btn i { font-size:18px; }
.icon-btn:hover { border-color:#FFEB3B; color:#FFEB3B; }
.btn-portal { font-size:13px; padding:6px 14px; color:#FFEB3B; border:1px solid #FFEB3B; background:transparent; border-radius:4px; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:all .15s; text-decoration:none; }
.btn-portal:hover { background:rgba(255,235,59,0.1); color:#FFEB3B; }

/* ── PAGE VIEWS ──────────────────────────────────────────── */
.page-view { display:none; padding:28px; flex:1; }
.page-view.active { display:block; }
.page-title { font-size:20px; font-weight:700; color:var(--gp); margin-bottom:6px; }
.page-subtitle { font-size:13px; color:var(--text3); margin-bottom:24px; }

/* ── CARDS ───────────────────────────────────────────────── */
.card { background:var(--card); border-radius:var(--radius-lg); border:1.5px solid var(--border); padding:24px; }
.stat-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:14px; margin-bottom:24px; }
.stat-card { background:var(--card); border-radius:var(--radius-lg); border:1.5px solid var(--border); padding:18px 20px; display:flex; align-items:center; gap:14px; }
.stat-icon { width:44px; height:44px; border-radius:10px; flex-shrink:0; display:flex; align-items:center; justify-content:center; }
.stat-icon i { font-size:22px; }
.stat-label { font-size:11px; color:var(--text3); font-weight:500; }
.stat-val   { font-size:24px; font-weight:700; color:var(--text); }

/* ── FORM ────────────────────────────────────────────────── */
.form-label { display:block; font-size:11px; font-weight:700; color:var(--text2); margin-bottom:6px; letter-spacing:.3px; text-transform:uppercase; }
.form-input { width:100%; padding:10px 14px; border:1.5px solid var(--border); border-radius:var(--radius); font-size:13px; color:var(--text); background:#f8fafc; outline:none; transition:border-color .2s; }
.form-input:focus { border-color:var(--gs); background:#fff; box-shadow:0 0 0 3px rgba(30,144,255,.1); }
.form-field { margin-bottom:16px; }
.btn-primary { padding:10px 22px; background:var(--gp); color:#fff; border:none; border-radius:var(--radius); font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:background .15s; }
.btn-primary:hover { background:var(--gp2); }
.btn-primary:disabled { opacity:.6; cursor:not-allowed; }
.btn-secondary { padding:10px 20px; border:1.5px solid var(--border); border-radius:var(--radius); font-size:13px; background:transparent; color:var(--text2); cursor:pointer; font-weight:500; display:inline-flex; align-items:center; gap:6px; transition:all .15s; }
.btn-secondary:hover { border-color:var(--gs); color:var(--gs); }
.btn-danger { padding:10px 20px; background:var(--danger); color:#fff; border:none; border-radius:var(--radius); font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px; }
.btn-success { padding:10px 20px; background:#166534; color:#fff; border:none; border-radius:var(--radius); font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px; }
.btn-ai { padding:10px 20px; background:linear-gradient(135deg,#003366,#1E90FF); color:#fff; border:none; border-radius:var(--radius); font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:opacity .15s; }
.btn-ai:hover { opacity:.88; }
.btn-ai:disabled { opacity:.5; cursor:not-allowed; }

/* ── TABLE ───────────────────────────────────────────────── */
.table-wrap { overflow-x:auto; }
.data-table { width:100%; border-collapse:collapse; background:var(--card); border-radius:var(--radius-lg); overflow:hidden; border:1.5px solid var(--border); font-size:13px; min-width:800px; }
.data-table th { text-align:left; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:var(--text3); padding:12px 16px; background:#f8fafc; border-bottom:1.5px solid var(--border); white-space:nowrap; }
.data-table td { padding:11px 16px; color:var(--text); border-bottom:1px solid var(--border); white-space:nowrap; }
.data-table tr:last-child td { border-bottom:none; }
.data-table tr:hover td { background:#f8fafc; }
.badge { font-size:10px; padding:3px 10px; border-radius:12px; font-weight:600; }
.badge-success { background:#dcfce7; color:#166534; }
.badge-warn    { background:#fef3c7; color:#92400e; }
.badge-info    { background:#dbeafe; color:#1e40af; }

/* ── MODAL ───────────────────────────────────────────────── */
.modal-overlay { position:fixed; inset:0; background:rgba(0,20,50,.55); z-index:500; display:flex; align-items:center; justify-content:center; padding:20px; }
.modal { background:var(--white); border-radius:var(--radius-lg); width:100%; max-width:520px; max-height:90vh; overflow-y:auto; padding:28px; box-shadow:0 20px 60px rgba(0,51,102,.2); }
.modal-lg { max-width:780px; }
.modal-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px; }
.modal-title  { font-size:17px; font-weight:700; color:var(--gp); }
.modal-close  { width:32px; height:32px; border:none; background:#f1f5f9; border-radius:8px; cursor:pointer; font-size:18px; display:flex; align-items:center; justify-content:center; color:var(--text2); flex-shrink:0; }
.modal-close:hover { background:#e2e8f0; }
.modal-footer { display:flex; gap:10px; margin-top:20px; justify-content:flex-end; flex-wrap:wrap; }

/* ── UPLOAD ZONE ─────────────────────────────────────────── */
.upload-zone { border:2px dashed var(--border); border-radius:var(--radius-lg); padding:32px; text-align:center; transition:all .2s; cursor:pointer; }
.upload-zone:hover, .upload-zone.drag-over { border-color:var(--gs); background:#f0f7ff; }
.upload-zone i { font-size:40px; color:var(--text3); margin-bottom:10px; display:block; }
.upload-zone p  { font-size:13px; color:var(--text3); }
.upload-zone .upload-hint { font-size:11px; color:var(--text3); margin-top:4px; }

/* ── PREVIEW IMPORT ──────────────────────────────────────── */
.preview-tbl { width:100%; border-collapse:collapse; font-size:11px; max-height:200px; }
.preview-tbl th { background:var(--gp); color:#fff; padding:6px 10px; text-align:left; position:sticky; top:0; }
.preview-tbl td { padding:5px 10px; border-bottom:1px solid var(--border); }
.preview-tbl tr:nth-child(even) td { background:#f8fafc; }

/* ── STATISTIK CARD ──────────────────────────────────────── */
.stat-big { text-align:center; }
.stat-big .avg { font-size:40px; font-weight:800; color:var(--gp); line-height:1; }
.stat-big .kat { font-size:13px; color:var(--gs); font-weight:600; margin-top:4px; }
.stat-big .n   { font-size:11px; color:var(--text3); margin-top:2px; }

/* ── PROGRESS BAR ────────────────────────────────────────── */
.prog-bar-wrap { margin:4px 0; }
.prog-bar-row { display:flex; align-items:center; gap:8px; margin-bottom:4px; font-size:11px; }
.prog-bar-label { width:90px; color:var(--text2); flex-shrink:0; }
.prog-bar-bg { flex:1; height:8px; background:#e8edf5; border-radius:4px; overflow:hidden; }
.prog-bar-fill { height:8px; border-radius:4px; transition:width .4s; }

/* ── AI BOX ──────────────────────────────────────────────── */
.ai-box { background:linear-gradient(135deg,#f0f7ff,#e8f4ff); border:1.5px solid #1E90FF; border-radius:var(--radius-lg); padding:20px; margin-top:16px; }
.ai-box-header { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
.ai-box-header i { font-size:22px; color:var(--gp); }
.ai-box-title { font-size:14px; font-weight:700; color:var(--gp); }
.ai-result { font-size:13px; color:var(--text2); line-height:1.8; white-space:pre-line; background:#fff; border:1px solid var(--border); border-radius:var(--radius); padding:14px; margin-top:10px; }
.ai-model-badge { font-size:10px; background:#e0edff; color:var(--gp2); border-radius:8px; padding:2px 8px; font-weight:600; }

/* ── KEGIATAN LIST ───────────────────────────────────────── */
#kegiatan-list { overflow-x: auto; padding-bottom: 8px; }
.kegiatan-card { background:var(--card); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:18px 20px; margin-bottom:12px; display:flex; align-items:center; gap:16px; cursor:pointer; transition:all .2s; min-width:800px; }
.kegiatan-card:hover { border-color:var(--gs); box-shadow:var(--shadow); transform:translateY(-1px); }
.kegiatan-icon { width:42px; height:42px; border-radius:11px; background:#dbeafe; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.kegiatan-icon i { font-size:20px; color:#1e40af; }
.kegiatan-name { font-size:14px; font-weight:600; color:var(--text); }
.kegiatan-meta { font-size:11px; color:var(--text3); margin-top:3px; }
.kegiatan-actions { margin-left:auto; display:flex; gap:6px; }

/* ── SECTION TABS ────────────────────────────────────────── */
.section-tabs { display:flex; gap:6px; margin-bottom:20px; flex-wrap:wrap; }
.stab { padding:8px 18px; border-radius:var(--radius); border:1.5px solid var(--border); font-size:12px; font-weight:600; cursor:pointer; background:transparent; color:var(--text2); transition:all .15s; }
.stab.active { background:var(--gp); color:#fff; border-color:var(--gp); }
.stab:hover:not(.active) { border-color:var(--gs); color:var(--gs); }

/* ── FILTER TOOLBAR ──────────────────────────────────────── */
.filter-toolbar { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px; align-items:center; }
.search-wrap { position:relative; flex:1; min-width:200px; }
.search-wrap i { position:absolute; left:11px; top:50%; transform:translateY(-50%); font-size:17px; color:var(--text3); }
.search-input { width:100%; padding:9px 12px 9px 36px; border:1.5px solid var(--border); border-radius:var(--radius); font-size:13px; color:var(--text); background:var(--white); outline:none; }
.search-input:focus { border-color:var(--gs); }

/* ── EMPTY STATE ─────────────────────────────────────────── */
.empty-state { text-align:center; padding:60px 20px; color:var(--text3); }
.empty-state i { font-size:52px; margin-bottom:16px; display:block; opacity:.4; }
.empty-state p { font-size:14px; }
/* MOBILE OVERLAY & RESPONSIVENESS */
.sidebar-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 90; backdrop-filter: blur(2px); }
@media (max-width: 768px) {
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); box-shadow: 4px 0 24px rgba(0,0,0,0.2); }
  .main-content { margin-left: 0; width: 100%; }
  #btn-sidebar-toggle { display: flex !important; }
  #btn-sidebar-close { display: flex !important; }
  .form-input, .search-input, select { font-size: 16px !important; }
  .btn-primary, .btn-secondary, .btn-danger, .btn-success, .btn-ai { padding: 12px 16px !important; font-size: 14px !important; }
  .stat-grid { grid-template-columns: 1fr; }
  .data-table td { padding: 14px 10px; }
}
</style>
</head>

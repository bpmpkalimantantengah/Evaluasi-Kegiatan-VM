  // ── ADMIN INSTRUMEN ───────────────────────────────────────
  let _adminInstrumenData = { K: [], S: [], N: [] };

  async function loadAdminInstrumen() {
    const tbody = document.getElementById('admin-instrumen-tbody');
    if (tbody) tbody.innerHTML = '<tr><td colspan="3" style="text-align:center; padding:20px; color:var(--text3); font-size:13px;">Memuat data...</td></tr>';
    
    const r = await api('getInstrumenAdmin');
    if (r.success && r.data) {
      _adminInstrumenData = Object.assign({ K: [], S: [], N: [] }, r.data);
    } else {
      toast(r.error || 'Gagal memuat instrumen.', 'error');
    }
    renderAdminInstrumen();
  }

  function renderAdminInstrumen() {
    const tipe = document.getElementById('sel-instrumen-tipe').value || 'K';
    const tbody = document.getElementById('admin-instrumen-tbody');
    if (!tbody) return;
    const list = _adminInstrumenData[tipe] || [];
    
    if (list.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" style="text-align:center; padding:20px; color:var(--text3); font-size:13px;">Belum ada pertanyaan.</td></tr>';
      return;
    }

    tbody.innerHTML = list.map((item, idx) => `
      <tr>
        <td style="padding:12px; text-align:center;">${idx + 1}</td>
        <td style="padding:12px;">
          <input type="text" class="form-input instrumen-item" data-idx="${idx}" value="${escHtml(item)}" placeholder="Masukkan pertanyaan..." style="width:100%; border:1px solid #ddd; border-radius:4px; padding:6px 10px; font-size:13px;" onchange="Ev.updatePernyataanInstrumen(${idx}, this.value)" />
        </td>
        <td style="padding:12px; text-align:center;">
          <button class="btn-danger" style="padding:4px 8px; font-size:12px;" onclick="Ev.hapusPernyataanInstrumen(${idx})"><i class="ti ti-trash"></i></button>
        </td>
      </tr>
    `).join('');
  }
  
  function updatePernyataanInstrumen(idx, val) {
    const tipe = document.getElementById('sel-instrumen-tipe').value || 'K';
    _adminInstrumenData[tipe][idx] = val;
  }

  function tambahPernyataanInstrumen() {
    const tipe = document.getElementById('sel-instrumen-tipe').value || 'K';
    _adminInstrumenData[tipe].push('');
    renderAdminInstrumen();
  }

  function hapusPernyataanInstrumen(idx) {
    const tipe = document.getElementById('sel-instrumen-tipe').value || 'K';
    _adminInstrumenData[tipe].splice(idx, 1);
    renderAdminInstrumen();
  }

  async function simpanAdminInstrumen() {
    const tipe = document.getElementById('sel-instrumen-tipe').value || 'K';
    const inputs = document.querySelectorAll('.instrumen-item');
    const newList = [];
    inputs.forEach(input => {
      if (input.value.trim()) newList.push(input.value.trim());
    });
    
    _adminInstrumenData[tipe] = newList;
    
    const btn = event.currentTarget;
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border-width:2px;border-top-color:var(--gp);"></div> Menyimpan...';
    
    const r = await api('saveInstrumenAdmin', { tipe_evaluasi: tipe, pertanyaan_json: newList });
    
    btn.disabled = false;
    btn.innerHTML = oldHtml;
    
    if (r.success) {
      toast(r.message || 'Berhasil disimpan.', 'success');
      renderAdminInstrumen();
    } else {
      toast(r.error || 'Gagal menyimpan instrumen.', 'error');
    }
  }

  // ── UTILITAS ──────────────────────────────────────────────
  async function logout()          { 
    const btn = document.getElementById('btnLogout');
    if (btn) {
      btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="margin-right: 5px; width: 14px; height: 14px; color: #FFEB3B;"></span> Menuju Portal...';
      btn.style.pointerEvents = 'none';
      btn.style.opacity = '0.8';
    }
    window.top.location.href = <%- JSON.stringify(portalUrl || '') %>; 
  }
  async function refresh()         { 
    await loadKegiatanList(); 
    if(SSO_USER && (SSO_USER.role === 'ADMIN' || SSO_USER.role === 'SUPER_ADMIN')) await loadAdminTimKerja();
    renderDashboard(); 
    toast('Data diperbarui.', 'info'); 
  }

  return {
    init, showView, loadEvaluasi, evalTab, rangkumSaran,
    filterKegiatan, bukaEvaluasi, konfirmasiHapus,
    generateLaporanDocs, generateOnlyRingkasanAI, downloadXLSX,
    logout, refresh,
    showQRModal, generateQR, salinLink, downloadQR, fullscreenQR,
    loadAdminTimKerja, showAdminTimKerjaModal, editAdminTimKerja, saveAdminTimKerja, deleteAdminTimKerja,
    showKegiatanModal, editKegiatanModal, saveKegiatan, showResponden,
    loadAdminInstrumen, renderAdminInstrumen, tambahPernyataanInstrumen, hapusPernyataanInstrumen, simpanAdminInstrumen, updatePernyataanInstrumen
  };
})();

// ── GLOBAL HELPERS ─────────────────────────────────────────
function toggleSidebar(forceClose) {
  const sb = document.getElementById('sidebar');
  const ov = document.getElementById('sidebarOverlay');
  if (!sb || !ov) return;
  if (forceClose === true) {
    sb.classList.remove('open');
    ov.style.display = 'none';
  } else {
    const isOp = sb.classList.toggle('open');
    ov.style.display = isOp ? 'block' : 'none';
  }
}

function showView(viewId, navEl) {
  document.querySelectorAll('.page-view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('view-' + viewId).classList.add('active');
  if (navEl) navEl.classList.add('active');
  if(window.innerWidth <= 768) toggleSidebar(true);

  if (viewId === 'instrumen') {
    Ev.loadAdminInstrumen();
  } else if (viewId === 'laporan') {
    const lapSel = document.getElementById('lap-kegiatan-select');
    if (lapSel) lapSel.value = '';
    const aiCont = document.getElementById('ai-summary-container');
    if (aiCont) aiCont.style.display = 'none';
  }
}

function closeModal(id)     { document.getElementById(id).classList.add('hidden'); }
function showToast(msg, type) {
  const icons = { success:'ti-check', error:'ti-alert-circle', info:'ti-info-circle', warning:'ti-alert-triangle' };
  const el = document.createElement('div');
  el.className = 'gaspol-toast toast-' + (type||'info');
  el.innerHTML = `<i class="ti ${icons[type]||'ti-info-circle'}"></i> ${msg}`;
  document.getElementById('toast-wrap').appendChild(el);
  setTimeout(() => el.remove(), 3000);
}
function toast(msg, type) { showToast(msg, type); } // alias backward compat
function escHtml(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function escJs(s)   { return String(s||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/"/g,'\\"'); }

window.onerror = function(msg, src, line, col, err) {
  console.error('Error JS:', msg, 'Line:', line);
};
window.addEventListener('unhandledrejection', function(e) {
  console.error('Promise Error:', (e.reason && e.reason.message ? e.reason.message : e.reason));
});

window.addEventListener('load', () => {
  Ev.init();
});
</script>

</body>
</html>

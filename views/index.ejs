  // ── MANAJEMEN KEGIATAN ─────────────────────────────────────
  function showKegiatanModal() {
    document.getElementById('mdl-keg-title').textContent = 'Tambah Kegiatan';
    document.getElementById('mdl-keg-oldnama').value = '';
    document.getElementById('mdl-keg-nama').value = '';
    document.getElementById('mdl-keg-tahun').value = new Date().getFullYear();
    document.getElementById('mdl-keg-timkerja').value = '';
    const elMulai = document.getElementById('mdl-keg-tglmulai');
    const elAkhir = document.getElementById('mdl-keg-tglakhir');
    if (elMulai._flatpickr) elMulai._flatpickr.clear(); else elMulai.value = '';
    if (elAkhir._flatpickr) elAkhir._flatpickr.clear(); else elAkhir.value = '';
    document.getElementById('mdl-keg-tempat').value = '';
    document.getElementById('mdl-keg-penanggungjawab').value = '';
    document.getElementById('mdl-keg-narasumber').value = '';
    document.getElementById('modal-kegiatan').classList.remove('hidden');
  }

  function editKegiatanModal(oldNama, timKerja, tahun, tglMulai, tglAkhir, tempat, penanggungjawab, narasumberList) {
    document.getElementById('mdl-keg-title').textContent = 'Edit Kegiatan';
    document.getElementById('mdl-keg-oldnama').value = oldNama;
    document.getElementById('mdl-keg-nama').value = oldNama;
    document.getElementById('mdl-keg-tahun').value = tahun || new Date().getFullYear();
    document.getElementById('mdl-keg-timkerja').value = timKerja || '';
    
    const formatInputDate = (d) => {
      if (!d) return '';
      try {
        const dateObj = new Date(d);
        if (isNaN(dateObj)) return '';
        const yyyy = dateObj.getFullYear();
        const mm = String(dateObj.getMonth() + 1).padStart(2, '0');
        const dd = String(dateObj.getDate()).padStart(2, '0');
        return `${yyyy}-${mm}-${dd}`;
      } catch(e) { return ''; }
    };
    const elMulai = document.getElementById('mdl-keg-tglmulai');
    const elAkhir = document.getElementById('mdl-keg-tglakhir');
    const fm = formatInputDate(tglMulai);
    const fa = formatInputDate(tglAkhir);
    if (elMulai._flatpickr) elMulai._flatpickr.setDate(fm); else elMulai.value = fm;
    if (elAkhir._flatpickr) elAkhir._flatpickr.setDate(fa); else elAkhir.value = fa;
    document.getElementById('mdl-keg-tempat').value = tempat || '';
    document.getElementById('mdl-keg-penanggungjawab').value = penanggungjawab || '';
    document.getElementById('mdl-keg-narasumber').value = narasumberList || '';
    document.getElementById('modal-kegiatan').classList.remove('hidden');
  }

  async function saveKegiatan() {
    const oldNama     = document.getElementById('mdl-keg-oldnama').value;
    const newNama     = document.getElementById('mdl-keg-nama').value.trim();
    const newTahun    = document.getElementById('mdl-keg-tahun').value.trim();
    const newTimKerja = document.getElementById('mdl-keg-timkerja').value;
    const tglMulai    = document.getElementById('mdl-keg-tglmulai').value;
    const tglAkhir    = document.getElementById('mdl-keg-tglakhir').value;
    const tempat      = document.getElementById('mdl-keg-tempat').value.trim();
    const penanggungjawab = document.getElementById('mdl-keg-penanggungjawab').value.trim();
    const narasumberList = document.getElementById('mdl-keg-narasumber').value.trim();
    
    if (!newNama) return toast('Nama kegiatan wajib diisi.', 'error');

    const action = oldNama ? 'editKegiatan' : 'addKegiatan';
    const payload = oldNama ? 
      { oldNama, newNama, newTimKerja, newTahun, tglMulai, tglAkhir, tempat, penanggungjawab, narasumberList } : 
      { namaKegiatan: newNama, timKerja: newTimKerja, tahun: newTahun, tglMulai, tglAkhir, tempat, penanggungjawab, narasumberList };

    const btn = document.getElementById('btn-save-kegiatan');
    if(btn) {
      btn.disabled = true;
      btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border-width:2px;border-top-color:var(--gp);"></div> Menyimpan...';
    }

    const r = await api(action, payload);
    
    if(btn) {
      btn.disabled = false;
      btn.innerHTML = '<i class="ti ti-device-floppy"></i> Simpan';
    }

    if (r.success) {
      closeModal('modal-kegiatan');
      toast(r.message, 'success');
      await loadKegiatanList();
      renderDashboard();
    } else {
      toast(r.error || 'Gagal menyimpan.', 'error');
    }
  }

  // ── MODAL QR CODE ───────────────────────────────────────
  let _qrCurrentKegiatan = '';
  let _qrCurrentCode = '';

  function showQRModal(nama, kodeUnik) {
    _qrCurrentKegiatan = nama;
    _qrCurrentCode = kodeUnik;
    document.getElementById('qr-kegiatan-title').textContent = nama;
    document.getElementById('modal-qr').classList.remove('hidden');
    generateQR();
  }

  function generateQR() {
    const container = document.getElementById('qrcode-container');
    container.innerHTML = '';
    
    // Gunakan kode unik jika ada, fallback ke nama kegiatan
    const url = _qrCurrentCode 
      ? `https://168-110-208-72.nip.io/evaluasi.html?c=${encodeURIComponent(_qrCurrentCode)}`
      : `https://168-110-208-72.nip.io/evaluasi.html?kegiatan=${encodeURIComponent(_qrCurrentKegiatan)}`;
    
    document.getElementById('qr-link-text').innerHTML = `<a href="${url}" target="_blank" style="color:var(--gs); text-decoration:underline;">${url}</a>`;
    
    new QRCode(container, {
      text: url,
      width: 1024,
      height: 1024,
      colorDark : "#000000",
      colorLight : "#ffffff",
      correctLevel : QRCode.CorrectLevel.H
    });

    // Sesuaikan ukuran tampilan di modal agar tidak menutupi layar
    setTimeout(() => {
      const cvs = container.querySelector('canvas');
      const img = container.querySelector('img');
      if (cvs) { cvs.style.width = '200px'; cvs.style.height = '200px'; }
      if (img) { img.style.width = '200px'; img.style.height = '200px'; }
    }, 50);
  }

  function salinLink() {
    const url = _qrCurrentCode 
      ? `https://168-110-208-72.nip.io/evaluasi.html?c=${encodeURIComponent(_qrCurrentCode)}`
      : `https://168-110-208-72.nip.io/evaluasi.html?kegiatan=${encodeURIComponent(_qrCurrentKegiatan)}`;
    navigator.clipboard.writeText(url).then(() => {
      toast('Link berhasil disalin!', 'success');
    }).catch(err => {
      toast('Gagal menyalin link.', 'error');
    });
  }

  function downloadQR() {
    const canvas = document.querySelector('#qrcode-container canvas');
    if (canvas) {
      // Pastikan background putih untuk JPEG
      const tempCanvas = document.createElement('canvas');
      tempCanvas.width = canvas.width;
      tempCanvas.height = canvas.height;
      const ctx = tempCanvas.getContext('2d');
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, tempCanvas.width, tempCanvas.height);
      ctx.drawImage(canvas, 0, 0);

      const a = document.createElement('a');
      a.href = tempCanvas.toDataURL('image/jpeg', 1.0);
      a.download = `QR_Code_${_qrCurrentCode || _qrCurrentKegiatan}.jpg`;
      a.click();
    } else {
      toast('QR Code belum dimuat.', 'warning');
    }
  }

  function fullscreenQR() {
    const canvas = document.querySelector('#qrcode-container canvas');
    if (!canvas) return toast('QR Code belum dimuat.', 'warning');

    const overlay = document.createElement('div');
    overlay.style.position = 'fixed';
    overlay.style.top = '0';
    overlay.style.left = '0';
    overlay.style.width = '100vw';
    overlay.style.height = '100vh';
    overlay.style.backgroundColor = 'white';
    overlay.style.zIndex = '9999';
    overlay.style.display = 'flex';
    overlay.style.flexDirection = 'column';
    overlay.style.justifyContent = 'center';
    overlay.style.alignItems = 'center';
    
    const title = document.createElement('h2');
    title.textContent = _qrCurrentKegiatan;
    title.style.marginBottom = '30px';
    title.style.color = 'var(--gp)';
    title.style.textAlign = 'center';
    title.style.padding = '0 20px';

    const img = document.createElement('img');
    
    // Pastikan background putih untuk JPEG
    const tempCanvas = document.createElement('canvas');
    tempCanvas.width = canvas.width;
    tempCanvas.height = canvas.height;
    const ctx = tempCanvas.getContext('2d');
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, tempCanvas.width, tempCanvas.height);
    ctx.drawImage(canvas, 0, 0);

    img.src = tempCanvas.toDataURL('image/jpeg', 1.0);
    img.style.maxWidth = '90vmin';
    img.style.maxHeight = '80vmin';
    img.style.objectFit = 'contain';

    const closeBtn = document.createElement('button');
    closeBtn.className = 'btn-danger';
    closeBtn.innerHTML = '<i class="ti ti-x"></i> Tutup Fullscreen';
    closeBtn.style.position = 'absolute';
    closeBtn.style.top = '20px';
    closeBtn.style.right = '20px';
    closeBtn.onclick = () => document.body.removeChild(overlay);

    overlay.appendChild(closeBtn);
    overlay.appendChild(title);
    overlay.appendChild(img);
    document.body.appendChild(overlay);
  }


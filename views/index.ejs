  function formatAIToHTML(text) {
    if (!text) return '';
    const lines = text.split('\n');
    let html = '<ol style="padding-left: 20px; margin: 0; display:flex; flex-direction:column; gap:6px; font-family: inherit;">';
    lines.forEach(line => {
      line = line.trim();
      if (line) {
        line = line.replace(/^\d+[\.\)]\s*/, '').replace(/^[-*]\s+/, '');
        let escapedLine = escHtml(line);
        escapedLine = escapedLine.replace(/\*\*(.*?)\*\*/g, '<b>$1</b>');
        html += `<li>${escapedLine}</li>`;
      }
    });
    html += '</ol>';
    return html;
  }

  // ── RANGKUM SARAN DENGAN AI ───────────────────────────────
  async function rangkumSaran(tipe, namaNarasumber) {
    const idx = namaNarasumber
      ? (_evalData && _evalData.N ? _evalData.N.perNS.findIndex(ns => ns.narasumber === namaNarasumber) : -1)
      : -1;
    const btnId    = tipe === 'N' ? 'btn-ai-N-' + idx    : 'btn-ai-' + tipe;
    const resultId = tipe === 'N' ? 'ai-result-N-' + idx : 'ai-result-' + tipe;

    const btn    = document.getElementById(btnId);
    const resEl  = document.getElementById(resultId);
    if (!btn || !resEl) return;

    btn.disabled = true;
    btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border-width:2px;"></div> Sedang merangkum...';
    resEl.style.display = 'none';

    const r = await api('rangkumSaran', {
      namaKegiatan  : _evalNama,
      tipe          : tipe,
      namaNarasumber: namaNarasumber || null,
    });

    btn.disabled = false;
    btn.innerHTML = '<i class="ti ti-sparkles"></i> Rangkum Ulang (AI)';

    if (!r.success) {
      toast(r.error || 'Gagal merangkum saran.', 'error');
      resEl.style.display = 'none';
      return;
    }

    resEl.style.display = 'block';
    resEl.innerHTML = `
      <div class="ai-result" id="ai-text-${btnId}"></div>
      <div style="margin-top:8px;display:flex;gap:8px;align-items:center;font-size:11px;color:var(--text3);">
        <span>${r.jumlahSaran} saran dirangkum</span>
      </div>`;

    if (!window.aiIntervals) window.aiIntervals = {};
    if (window.aiIntervals[btnId]) clearInterval(window.aiIntervals[btnId]);

    const textEl = document.getElementById(`ai-text-${btnId}`);
    const text = r.ringkasan || '';
    
    textEl.innerHTML = formatAIToHTML(text);

    toast('Ringkasan AI berhasil dibuat!', 'success');
  }

  // ── UNDUH DATA MENTAH (XLSX) ──────────────────────────────
  async function downloadXLSX() {
    const namaKegiatan = document.getElementById('lap-kegiatan-select').value;
    if (!namaKegiatan) {
      toast('Silakan pilih kegiatan terlebih dahulu!', 'warning');
      return;
    }

    const btn = document.getElementById('btn-gen-csv');
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block;vertical-align:middle;margin-right:8px;"></div> Mengunduh XLSX...';

    try {
      const url = `https://168-110-208-72.nip.io/api/evaluasi/rekap/${encodeURIComponent(namaKegiatan)}`;
      const response = await fetch(url);
      const resData = await response.json();

      if (!resData.success) {
        throw new Error(resData.error || 'Gagal mengambil data rekap dari server.');
      }

      const allData = Array.isArray(resData.data) ? resData.data : [];
      const dataK = allData.filter(d => d.tipe_evaluasi === 'K');
      const dataS = allData.filter(d => d.tipe_evaluasi === 'S');
      const dataN = allData.filter(d => d.tipe_evaluasi === 'N');

      const wb = XLSX.utils.book_new();

      if (dataK.length > 0) {
        const wsK = XLSX.utils.json_to_sheet(dataK);
        XLSX.utils.book_append_sheet(wb, wsK, "Keterlaksanaan (K)");
      }
      if (dataS.length > 0) {
        const wsS = XLSX.utils.json_to_sheet(dataS);
        XLSX.utils.book_append_sheet(wb, wsS, "Sarana Prasarana (S)");
      }
      if (dataN.length > 0) {
        const wsN = XLSX.utils.json_to_sheet(dataN);
        XLSX.utils.book_append_sheet(wb, wsN, "Narasumber (N)");
      }

      if (dataK.length === 0 && dataS.length === 0 && dataN.length === 0) {
        const wsEmpty = XLSX.utils.json_to_sheet([{ Info: "Tidak ada data evaluasi untuk kegiatan ini." }]);
        XLSX.utils.book_append_sheet(wb, wsEmpty, "Data Kosong");
      }

      XLSX.writeFile(wb, `RawData_${namaKegiatan}.xlsx`);

      toast('Data mentah (XLSX) berhasil diunduh!', 'success');
    } catch (err) {
      toast(err.message, 'error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = oldHtml;
    }
  }



  // "?"? GENERATE LAPORAN "?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?"?
  async function generateLaporanDocs() {
    const nama = document.getElementById('lap-kegiatan-select').value;
    if (!nama) { toast('Pilih kegiatan terlebih dahulu.', 'error'); return; }

    const btn = document.getElementById('btn-gen-lap');
    btn.disabled = true;
    btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border:2px solid rgba(255,255,255,0.3);border-top-color:var(--ga);"></div> Memproses...';

    let cbAI = document.getElementById('cb-ai-all');
    let ringkasanAI = null;
    const container = document.getElementById('ai-summary-container');
    const content = document.getElementById('ai-summary-content');

    if (cbAI && cbAI.checked) {
      if (container && container.style.display === 'block' && content && content.dataset.raw) {
        // Re-use text yang sudah di-generate di layar jika kotak dicentang
        ringkasanAI = content.dataset.raw;
      } else {
        toast('Sedang merangkum seluruh saran dengan AI. Mohon tunggu...', 'info');
        const ai = await api('rangkumSemuaSaran', { namaKegiatan: nama });
        
        if (ai.success) {
          ringkasanAI = ai.ringkasan;
          container.style.display = 'block';
          content.dataset.raw = ringkasanAI;
          content.innerHTML = formatAIToHTML(ringkasanAI);
        } else {
          if (ai.fallbackText) {
            toast('AI terkendala. Menampilkan seluruh saran secara langsung.', 'info');
            ringkasanAI = ai.fallbackText;
            container.style.display = 'block';
            content.dataset.raw = ringkasanAI;
            content.innerHTML = formatAIToHTML(ringkasanAI);
          } else if (ai.error && ai.error.includes("Tidak ada saran")) {
            ringkasanAI = "Tidak ada saran yang diberikan oleh responden.";
            container.style.display = 'block';
            content.dataset.raw = ringkasanAI;
            content.innerHTML = formatAIToHTML(ringkasanAI);
          } else {
            toast('AI Gagal: ' + ai.error, 'error');
          }
        }
      }
    }

    btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border:2px solid rgba(255,255,255,0.3);border-top-color:var(--ga);"></div> Membuat File DOCX...';
    toast('Membuat dokumen dari template, mohon tunggu...', 'info');

    const r = await api('generateLaporanDocs', { namaKegiatan: nama, ringkasanAI: ringkasanAI });

    btn.disabled = false;
    btn.innerHTML = '<i class="ti ti-file-text"></i> Generate Laporan';

    if (!r.success) { 
      toast(r.error || 'Gagal membuat file DOCX.', 'error'); 
      return; 
    }
    
    toast('Berhasil! File Laporan DOCX Anda sedang diunduh.', 'success');
    if (r.base64) {
      const a = document.createElement('a');
      a.href = 'data:application/vnd.openxmlformats-officedocument.wordprocessingml.document;base64,' + r.base64;
      a.download = r.filename || 'Laporan_Evaluasi.docx';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    }
  }

  async function generateOnlyRingkasanAI() {
    const nama = document.getElementById('lap-kegiatan-select').value;
    if (!nama) { toast('Pilih kegiatan terlebih dahulu.', 'error'); return; }
    
    const cbAI = document.getElementById('cb-ai-all');
    const isAIChecked = cbAI && cbAI.checked;

    const btn = document.getElementById('btn-gen-ai-only');
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border:2px solid rgba(0,0,0,0.3);border-top-color:var(--text);"></div> Memproses...';
    
    let ai;
    if (isAIChecked) {
      toast('Sedang merangkum seluruh saran dengan AI. Mohon tunggu...', 'info');
      ai = await api('rangkumSemuaSaran', { namaKegiatan: nama });
    } else {
      toast('Menarik seluruh saran dari sistem...', 'info');
      ai = await api('getSemuaSaranMentah', { namaKegiatan: nama });
    }
    
    btn.disabled = false;
    btn.innerHTML = oldHtml;

    const container = document.getElementById('ai-summary-container');
    const content = document.getElementById('ai-summary-content');
    
    if (ai.success) {
      container.style.display = 'block';
      const resultText = isAIChecked ? ai.ringkasan : ai.text;
      content.dataset.raw = resultText;
      content.innerHTML = formatAIToHTML(resultText);
      toast(isAIChecked ? 'Berhasil membuat ringkasan AI!' : 'Berhasil menampilkan seluruh saran!', 'success');
    } else {
      let text = '';
      if (ai.fallbackText) {
        toast('AI terkendala. Menampilkan seluruh saran secara langsung.', 'info');
        text = ai.fallbackText;
      } else if (ai.error && ai.error.includes("Tidak ada saran")) {
        text = "Tidak ada saran yang diberikan oleh responden.";
      } else {
        toast('Gagal: ' + ai.error, 'error');
        return;
      }
      container.style.display = 'block';
      content.dataset.raw = text;
      content.innerHTML = formatAIToHTML(text);
    }
  }




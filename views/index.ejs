<script>
// ── Konstanta Aplikasi (dari server) ──────────────────────
const APP_URL    = <%- JSON.stringify(appUrl || '') %>;
const APP_ID     = <%- JSON.stringify(appId || '') %>;
const TOKEN      = <%- JSON.stringify(token || '') %>;
const PORTAL_URL = <%- JSON.stringify(portalUrl || 'https://168-110-208-72.nip.io/portal/') %>;
const SSO_USER   = <%- ssoUser ? ssoUser : 'null' %>;

const Ev = (() => {
  let _kegiatan    = [];   // daftar kegiatan dari server
  let _evalData    = null; // data evaluasi yang sedang dilihat
  let _ssUrl       = null;
  let _activeView  = 'dashboard';
  let _evalNama    = '';
  let _adminTimKerjaList = [];

  // ── INIT ─────────────────────────────────────────────────
  async function init() {
    console.log('Evaluasi App Initing...');
    if(typeof flatpickr !== 'undefined') {
      const fpCfg = { altInput: true, altFormat: "d/m/Y", dateFormat: "Y-m-d", locale: "id" };
      flatpickr("#mdl-keg-tglmulai", fpCfg);
      flatpickr("#mdl-keg-tglakhir", fpCfg);
    }
    try {
      // Info user dari SSO
      if (typeof SSO_USER !== 'undefined' && SSO_USER) {
        const u = SSO_USER;
        const ini = (u.fullName || '').split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase();
        
        // Sidebar
        const sbAvatar = document.getElementById('sidebar-avatar');
        if (sbAvatar) sbAvatar.textContent = ini;
        const sbName = document.getElementById('sidebar-name');
        if (sbName) sbName.textContent   = u.fullName;
        const sbRole = document.getElementById('sidebar-role');
        if (sbRole) sbRole.textContent   = u.role;

        // Topbar
        const tbName = document.getElementById('topbar-user-name');
        if (tbName) tbName.textContent = u.fullName;
        const tbRole = document.getElementById('topbar-user-role');
        if (tbRole) tbRole.textContent = u.role;

        // Admin menu
        if (u.role === 'ADMIN' || u.role === 'SUPER_ADMIN') {
          document.querySelectorAll('.admin-only').forEach(el => el.style.display = '');
          loadAdminTimKerja();
        }
      }

      console.log('Loading kegiatan list...');
      await loadKegiatanList();

      console.log('Rendering dashboard...');
      renderDashboard();

    } catch (err) {
      console.error('Init error:', err);
      toast('Terjadi kesalahan saat memuat aplikasi: ' + err.message, 'error');
    } finally {
      console.log('Init finished.');
    }
  }

  // ── API CALL (Node.js VM via fetch) ─────────────────────
  async function api(action, data = {}) {
    try {
      const res = await fetch(APP_URL + '/api/action', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${TOKEN}`
        },
        body: JSON.stringify({ action, ...data })
      });
      if (!res.ok) return { success: false, error: 'HTTP ' + res.status };
      const obj = await res.json();
      // Deteksi sesi berakhir
      if (obj && obj.success === false && obj.error && obj.error.includes('Sesi telah berakhir')) {
        toast(obj.error, 'error');
        setTimeout(() => { window.top.location.href = PORTAL_URL; }, 2000);
        return obj;
      }
      return obj;
    } catch (e) {
      console.error('[API Error]', e);
      return { success: false, error: e.message };
    }
  }

  // ── LOAD DAFTAR KEGIATAN ──────────────────────────────────
  async function loadKegiatanList() {
    const r = await api('getSemuaKegiatan');
    _kegiatan = r.success ? (r.data || []) : [];

    // Isi select options di evaluasi & laporan
    _populateKegiatanSelects();
    _populateFilterOptions();
    renderKegiatanList();
  }

  function _populateKegiatanSelects() {
    ['eval-kegiatan-select', 'lap-kegiatan-select'].forEach(id => {
      const sel = document.getElementById(id);
      if (!sel) return;
      const cur = sel.value;
      sel.innerHTML = '<option value="">-- Pilih Kegiatan --</option>' +
        _kegiatan.map(k => `<option value="${escHtml(k.namaKegiatan)}">${escHtml(k.namaKegiatan)}</option>`).join('');
      sel.value = cur;
    });
  }

  function _populateFilterOptions() {
    // Tahun
    const tahunSet = new Set(_kegiatan.map(k => k.tahun).filter(Boolean));
    const tahunSel = document.getElementById('filter-tahun');
    if (tahunSel) {
      const curTahun = tahunSel.value;
      tahunSel.innerHTML = '<option value="">Semua Tahun</option>' +
        [...tahunSet].sort((a,b)=>b-a).map(t => `<option value="${t}">${t}</option>`).join('');
      tahunSel.value = curTahun;
    }

    // Tim Kerja
    const tkSet = new Set(_kegiatan.map(k => k.timKerja).filter(Boolean));
    const tkSel = document.getElementById('filter-timkerja');
    if (tkSel) {
      const curTk = tkSel.value;
      tkSel.innerHTML = '<option value="">Semua Tim Kerja</option>' +
        [...tkSet].sort().map(t => `<option value="${escHtml(t)}">${escHtml(t)}</option>`).join('');
      tkSel.value = curTk;
    }
  }

  // ── DASHBOARD ─────────────────────────────────────────────
  function renderDashboard() {
    const totalK = _kegiatan.length;
    const totalR = _kegiatan.reduce((s, k) => s + (parseInt(k.respondK)||0), 0);
    const tahunSet = new Set(_kegiatan.map(k => k.tahun).filter(Boolean));

    const dsTotal = document.getElementById('ds-total');
    if (dsTotal) dsTotal.textContent = totalK;
    const dsResp = document.getElementById('ds-responden');
    if (dsResp) dsResp.textContent = totalR;
    const dsTahun = document.getElementById('ds-tahun');
    if (dsTahun) dsTahun.textContent = [...tahunSet].sort((a,b)=>b-a)[0] || new Date().getFullYear();

    const dsAvgK = document.getElementById('ds-avg-k');
    if (dsAvgK) {
      let sumK = 0, countK = 0;
      _kegiatan.forEach(k => {
        const val = parseFloat(k.avgK);
        if (!isNaN(val) && val > 0) {
          sumK += val;
          countK++;
        }
      });
      dsAvgK.textContent = countK > 0 ? (sumK / countK).toFixed(2) : '-';
    }

    // Kegiatan terbaru (5)
    const recent = [..._kegiatan].sort((a, b) => {
      const dateA = a.tglMulai ? new Date(a.tglMulai).getTime() : 0;
      const dateB = b.tglMulai ? new Date(b.tglMulai).getTime() : 0;
      if (dateB !== dateA) return dateB - dateA;
      return a.namaKegiatan.localeCompare(b.namaKegiatan);
    }).slice(0, 5);
    
    const recentEl = document.getElementById('dash-recent');
    if (recentEl) {
      if (!recent.length) {
        recentEl.innerHTML = '<div class="empty-state" style="padding:20px;"><i class="ti ti-clipboard-list" style="font-size:32px;"></i><p>Belum ada kegiatan</p></div>';
      } else {
        recentEl.innerHTML = recent.map(k => `
          <div style="display:flex;align-items:center;gap:10px;padding:10px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .2s;" onclick="Ev.bukaEvaluasi('${escJs(k.namaKegiatan)}')" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
            <div style="width:32px;height:32px;background:#dbeafe;border-radius:8px;display:flex;align-items:center;justify-content:center;">
              <i class="ti ti-clipboard-list" style="font-size:16px;color:#1e40af;"></i>
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:12px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escHtml(k.namaKegiatan)}</div>
              <div style="font-size:10px;color:var(--text3);">${escHtml(k.timKerja||'-')} · ${escHtml(String(k.tahun||'-'))}</div>
            </div>
          </div>`).join('');
      }
    }
  }

  // ── DAFTAR KEGIATAN ───────────────────────────────────────
  function renderKegiatanList(filtered) {
    const list = (filtered || _kegiatan).slice().sort((a, b) => {
      const dateA = a.tglMulai ? new Date(a.tglMulai).getTime() : 0;
      const dateB = b.tglMulai ? new Date(b.tglMulai).getTime() : 0;
      if (dateB !== dateA) return dateB - dateA;
      return a.namaKegiatan.localeCompare(b.namaKegiatan);
    });
    
    const el = document.getElementById('kegiatan-list');
    if (!el) return;
    if (!list.length) {
      el.innerHTML = '<div class="empty-state"><i class="ti ti-clipboard-list"></i><p>Belum ada kegiatan. Tambahkan kegiatan baru untuk memulai.</p></div>';
      return;
    }
    
    const role = (typeof SSO_USER !== 'undefined' && SSO_USER) ? SSO_USER.role : '';
    const username = (typeof SSO_USER !== 'undefined' && SSO_USER) ? SSO_USER.username : '';

    el.innerHTML = list.map(k => {
      const canEdit = (role === 'SUPER_ADMIN' || role === 'ADMIN' || k.createdBy === username);
      const totalRes = k.totalRes !== undefined ? k.totalRes : (parseInt(k.respondK)||0);
      
      let createdByText = k.createdBy || '-';
      
      const formatTgl = (tgl) => {
        if (!tgl) return '-';
        try {
          const d = new Date(tgl);
          if (isNaN(d.getTime())) return tgl;
          return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' });
        } catch(e) { return tgl; }
      };
      
      const tglStr = (k.tglMulai || k.tglAkhir) ? `${formatTgl(k.tglMulai)} s/d ${formatTgl(k.tglAkhir)}` : '-';

      return `
      <div class="kegiatan-card" onclick="Ev.bukaEvaluasi('${escJs(k.namaKegiatan)}')">
        <div class="kegiatan-icon"><i class="ti ti-clipboard-list"></i></div>
        <div style="flex:1;min-width:0;">
          <div class="kegiatan-name">${escHtml(k.namaKegiatan)}</div>
          <div class="kegiatan-meta">
            Tim Kerja: ${escHtml(k.timKerja||'-')} &nbsp;·&nbsp; Tahun: ${escHtml(String(k.tahun||'-'))} &nbsp;·&nbsp; Pelaksanaan: ${tglStr}
            <br>
            ${totalRes} Responden &nbsp;·&nbsp; Oleh: ${escHtml(createdByText)}
          </div>
        </div>
        <div class="kegiatan-actions" onclick="event.stopPropagation()">
          <button class="btn-primary" style="padding:6px 12px;font-size:11px;background:var(--gs);" onclick="Ev.showQRModal('${escJs(k.namaKegiatan)}', '${escJs(k.kodeUnik)}')">
            <i class="ti ti-qrcode"></i> QR Code Form
          </button>
          <button class="btn-secondary" style="padding:6px 12px;font-size:11px;" onclick="Ev.showResponden('${escJs(k.namaKegiatan)}')">
            <i class="ti ti-users"></i> Statistik
          </button>
          <button class="btn-secondary" style="padding:6px 12px;font-size:11px;" onclick="Ev.bukaEvaluasi('${escJs(k.namaKegiatan)}')">
            <i class="ti ti-chart-bar"></i> Analisis
          </button>
          ${canEdit ? `
          <button class="btn-secondary" style="padding:6px 10px;font-size:11px;" onclick="Ev.editKegiatanModal('${escJs(k.namaKegiatan)}', '${escJs(k.timKerja||'')}', '${escJs(k.tahun||'')}', '${escJs(k.tglMulai||'')}', '${escJs(k.tglAkhir||'')}', '${escJs(k.tempat||'')}', '${escJs(k.penanggungjawab||'')}', '${escJs(k.narasumberList||'')}')">
            <i class="ti ti-edit"></i>
          </button>
          <button class="btn-danger" style="padding:6px 10px;font-size:11px;" onclick="Ev.konfirmasiHapus('${escJs(k.namaKegiatan)}')">
            <i class="ti ti-trash"></i>
          </button>
          ` : ''}
        </div>
      </div>`;
    }).join('');
  }

  async function showResponden(nama) {
    const listEl = document.getElementById('responden-list-content');
    if (!listEl) return;
    listEl.innerHTML = '<div style="text-align:center; padding:20px;"><div class="spinner"></div> Memuat data...</div>';
    document.getElementById('modal-responden').classList.remove('hidden');
    
    try {
        const res = await fetch("https://168-110-208-72.nip.io/api/evaluasi/responden/" + encodeURIComponent(nama));
        const json = await res.json();
        if (json.success && json.data.length > 0) {
            listEl.innerHTML = '<ul style="list-style:none; padding:0; margin:0; text-align:left;">' + 
                json.data.map((r, i) => {
                    const d = new Date(r.tgl_submit);
                    const dtStr = d.toLocaleDateString('id-ID') + ' ' + d.toLocaleTimeString('id-ID');
                    const namaPeserta = r.nama_peserta ? r.nama_peserta : 'Anonim';
                    return `<li style="padding: 10px; border-bottom: 1px solid var(--border);">
                                <div style="font-weight:600;">${i+1}. ${escHtml(namaPeserta)}</div>
                                <div style="font-size:11px; color:var(--text-muted);">${dtStr}</div>
                            </li>`;
                }).join('') + '</ul>';
        } else {
            listEl.innerHTML = '<div style="text-align:center; padding:20px;">Belum ada responden.</div>';
        }
    } catch(e) {
        listEl.innerHTML = '<div style="color:red; text-align:center; padding:20px;">Gagal memuat data responden dari VM.</div>';
    }
  };

  function filterKegiatan(q) {
    const query  = (q || document.getElementById('inp-search-kegiatan').value || '').toLowerCase();
    const tahunSel = document.getElementById('filter-tahun');
    const tkSel = document.getElementById('filter-timkerja');
    const tahun  = tahunSel ? tahunSel.value : '';
    const tk     = tkSel ? tkSel.value : '';

    let filtered = _kegiatan;
    if (query)  filtered = filtered.filter(k => (k.namaKegiatan||'').toLowerCase().includes(query));
    if (tahun)  filtered = filtered.filter(k => String(k.tahun) === tahun);
    if (tk)     filtered = filtered.filter(k => (k.timKerja||'') === tk);

    renderKegiatanList(filtered);
  }

  // ── BUKA EVALUASI ─────────────────────────────────────────
  function bukaEvaluasi(nama) {
    document.getElementById('eval-kegiatan-select').value = nama;
    showView('evaluasi', document.getElementById('nav-evaluasi'));
    loadEvaluasi(nama);
  }

  async function loadEvaluasi(nama) {
    if (!nama) { document.getElementById('eval-content').classList.add('hidden'); return; }
    _evalNama = nama;

    // Spinner
    document.getElementById('eval-content').classList.remove('hidden');
    document.getElementById('eval-tab-k').innerHTML = '<div class="empty-state" style="padding:40px;"><div class="spinner" style="margin:auto;"></div></div>';

    const r = await api('getDetailKegiatan', { namaKegiatan: nama });
    if (!r.success) { toast(r.error || 'Gagal memuat data.', 'error'); return; }

    _evalData = r.data;
    evalTab('K', document.getElementById('stab-k'));
  }

  function evalTab(tipe, btn) {
    ['K','S','N'].forEach(t => {
      document.getElementById('eval-tab-' + t.toLowerCase()).classList.add('hidden');
      document.getElementById('stab-' + t.toLowerCase()).classList.remove('active');
    });
    document.getElementById('eval-tab-' + tipe.toLowerCase()).classList.remove('hidden');
    btn.classList.add('active');
    if (!_evalData) return;
    renderEvalTab(tipe);
  }

  function renderEvalTab(tipe) {
    const el  = document.getElementById('eval-tab-' + tipe.toLowerCase());
    const data = _evalData[tipe];

    if (!data) {
      el.innerHTML = `<div class="empty-state"><i class="ti ti-database-off"></i><p>Data ${tipe === 'K' ? 'Keterlaksanaan' : tipe === 'S' ? 'Sarana Prasarana' : 'Narasumber'} belum diimport untuk kegiatan ini.</p></div>`;
      return;
    }

    if (tipe === 'K' || tipe === 'S') {
      el.innerHTML = _renderSeksiKS(tipe, data);
    } else {
      el.innerHTML = _renderSeksiN(data);
    }
  }

